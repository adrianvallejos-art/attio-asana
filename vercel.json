{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    },
    "api/daily-reconcile.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/daily-reconcile",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
